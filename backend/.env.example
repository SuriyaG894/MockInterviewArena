# Environment Configuration Template
# Copy this file to .env and fill in your configuration values

# ============================================
# Server Configuration
# ============================================

# Node environment (development or production)
NODE_ENV=development

# Backend server port
PORT=5000

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:5173

# ============================================
# LLM Provider Configuration
# ============================================

# Choose ONE: groq, azure, or local
LLM_PROVIDER=groq

# --------- GROQ Configuration ---------
# Get your API key from: https://console.groq.com
# 1. Sign up or log in to Groq Console
# 2. Navigate to API Keys section
# 3. Click "Create API Key"
# 4. Copy the key here
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --------- AZURE Configuration ---------
# Get your connection string from Azure Portal
# 1. Create or access an AI Agent resource
# 2. Copy Connection String from the resource's Connection tab
AZURE_AI_AGENTS_CONNECTION_STRING=

# --------- Local LLM Configuration ---------
# Use this if running a local LLM server (e.g., Ollama, LM Studio)
# 1. Start your local LLM server (e.g., ollama serve)
# 2. Set the endpoint where it's running
# 3. Set the model name installed on your local server
LOCAL_LLM_ENDPOINT=http://localhost:11434
LOCAL_MODEL_NAME=mistral

# ============================================
# LLM Behavior Configuration
# ============================================

# Maximum time (in ms) to wait for LLM response before timeout
LLM_TIMEOUT=15000

# Number of retries if LLM call fails
LLM_MAX_RETRIES=2

# ============================================
# Optional: Additional Settings
# ============================================

# Log level (optional: debug, info, warn, error)
LOG_LEVEL=info

# Enable CORS for additional origins (optional)
# CORS_ORIGINS=http://localhost:3000,http://example.com
